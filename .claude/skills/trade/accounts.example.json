      },
      "main": {
        "account_no": "<主账户H开头账号>",
        "channel": "lb",
        "backup": "~/.longbridge/openapi/cli-auth.real-main.bak",
        "net_assets_usd": 0,
        "buying_power_usd": 0,
        "available_hkd": 0,
        "available_usd": 0,
        "max_finance_usd": 0
      },
      "intraday_margin": {
        "account_no": "<日内融H开头账号>",
        "channel": "lb",
        "backup": "~/.longbridge/openapi/cli-auth.intraday-margin.bak",
        "net_assets_usd": 0,
        "buying_power_usd": 0,
        "available_hkd": 0,
        "available_usd": 0,
        "max_finance_usd": 0
      }
    }
  },
  "tiger": {
    "config_path": "~/.tigeropen/",
